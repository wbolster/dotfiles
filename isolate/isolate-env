#!/usr/bin/env python3
# PYTHON_ARGCOMPLETE_OK

import argparse
import fnmatch
import operator
import os
import pathlib
import secrets
import subprocess
import sys
import tempfile
import typing
from collections.abc import Iterable, Iterator

try:
    import argcomplete  # type: ignore[import-not-found]
except ImportError:
    argcomplete = None

Bind = tuple[pathlib.Path, pathlib.Path]
Symlink = tuple[pathlib.Path, pathlib.Path]

XDG_RUNTIME_DIR = pathlib.Path("/run/user") / str(os.getuid())
BWRAP_BASE_ARGS = (
    "--die-with-parent",
    "--unshare-all",
    "--share-net",
    *("--dev", "/dev"),
    *("--dir", "/etc"),
    *("--proc", "/proc"),
    *("--perms", "0700", "--tmpfs", str(XDG_RUNTIME_DIR)),
    *("--tmpfs", "/tmp"),
    *("--tmpfs", str(pathlib.Path.home())),
)
ENV_VARS = (
    "EDITOR",
    "GIT_CONFIG_COUNT=1",
    "GIT_CONFIG_KEY_0=commit.gpgsign",
    "GIT_CONFIG_VALUE_0=false",
    "HOME",
    "LANG",
    "LC_*",
    "MANPATH",
    "NPM_CONFIG_IGNORE_SCRIPTS=true",
    "PATH",
    "PYTHONDONTWRITEBYTECODE",
    "REQUESTS_CA_BUNDLE",
    "SHELL",
    "TERM",
    "USER",
    "VISUAL",
)
PATH_ENV_VARS = ("PATH", "MANPATH")
RO_BIND_MOUNTS_GENERIC = (
    "/bin",
    "/sbin",
    "/lib",
    "/lib64",
    "/usr",
    "/var/lib/flatpak",
    "~/.config/git",
    "~/.local/npm",
    "~/.local/pipx",
    "~/.local/share/direnv/allow",
    "~/.local/share/man",
    "~/.local/share/mise",
    "~/.pyenv",
    "~/.rustup",
    "~/.vim",
    "~/dotfiles",
)
RO_BIND_MOUNTS_PROGRAMS = {}
RO_BIND_MOUNTS_ETC = (
    "/etc/ca-certificates",
    "/etc/ca-certificates.conf",
    "/etc/gai.conf",
    "/etc/host.conf",
    "/etc/hosts",
    "/etc/ld.so.cache",
    "/etc/ld.so.conf",
    "/etc/ld.so.conf.d",
    "/etc/nsswitch.conf",
    "/etc/pki",
    "/etc/protocols",
    "/etc/services",
    "/etc/ssl",
)
REMOUNT_RO_BIND_MOUNTS = (
    "/",
    "/dev",
)
RW_BIND_MOUNTS_GENERIC = ()
RW_BIND_MOUNTS_PROGRAMS = {
    "claude": ("~/.claude", "~/.claude.json"),
    "codex": ("~/.codex",),
}
SHELL_RO_BIND_MOUNTS_GENERIC = (
    "~/.config/bat",
    "~/.config/ripgrep",
    "~/.inputrc",
    "~/.less",
    "~/.profile",
)
SHELL_RO_BIND_MOUNTS = {
    "bash": (
        "~/.bash_login",
        "~/.bash_logout",
        "~/.bash_profile",
        "~/.bashrc",
    ),
    "fish": ("~/.config/fish",),
    "zsh": (
        "~/.zlogin",
        "~/.zlogout",
        "~/.zprofile",
        "~/.zshenv",
        "~/.zshrc",
    ),
}
SHELL_ENV_VARS = (
    "GIT_PS1_*",
    "IGNOREEOF",
    "RIPGREP_CONFIG_PATH",
)


def main() -> None:
    args = parse_args()
    cwd = pathlib.Path.cwd()
    env_vars = obtain_env_vars([*ENV_VARS, *args.env])
    ro_binds, symlinks = normalize_binds_or_symlinks(RO_BIND_MOUNTS_GENERIC)
    ro_binds += normalize_binds(RO_BIND_MOUNTS_ETC)
    ro_binds += normalize_binds(
        ("/etc/resolv.conf", "/etc/localtime"),
        resolve_symlinks=True,
    )
    ro_binds += args.ro
    rw_binds: list[Bind] = [*normalize_binds(RW_BIND_MOUNTS_GENERIC), *args.rw]
    symlinks.append((pathlib.Path("/.isolate-env"), cwd))

    match args.subcommand:
        case "run":
            command = args.command
            program = pathlib.Path(command[0]).name
            ro_binds += normalize_binds(RO_BIND_MOUNTS_PROGRAMS.get(program, ()))
            rw_binds += normalize_binds(RW_BIND_MOUNTS_PROGRAMS.get(program, ()))
        case "shell":
            shell = pathlib.Path(os.environ.get("SHELL", "/bin/sh"))
            command = [shell]
            env_vars |= obtain_env_vars(SHELL_ENV_VARS)
            ro_binds += normalize_binds(SHELL_RO_BIND_MOUNTS_GENERIC)
            ro_binds += normalize_binds(SHELL_RO_BIND_MOUNTS.get(shell.name, ()))
            if history_bind := shell_history_bind(shell, cwd):
                rw_binds.append(history_bind)
                source, _ = history_bind
                source.parent.mkdir(parents=True, exist_ok=True)
                source.touch(mode=0o600)

    env_vars |= {
        "ISOLATE_ENV": str(cwd),
        "XDG_RUNTIME_DIR": str(XDG_RUNTIME_DIR),
    }

    match args.cwd:
        case "ro":
            ro_binds.append((cwd, cwd))
        case "rw":
            rw_binds.append((cwd, cwd))
        case "no":
            pass

    if args.docker:
        docker_host, docker_socket = detect_docker()
        if docker_socket:
            rw_binds.append((docker_socket, pathlib.Path("/var/run/docker.sock")))
        else:
            env_vars["DOCKER_HOST"] = docker_host

    match args.gpg:
        case None:
            pass
        case "ro" | "rw":
            gnupg_home, gnupg_socket_dir = detect_gnupg()
            if "GNUPGHOME" in os.environ:
                env_vars["GNUPGHOME"] = str(gnupg_home)
            ro_binds.append((gnupg_socket_dir, gnupg_socket_dir))
            if args.gpg == "ro":
                ro_binds.append((gnupg_home, gnupg_home))
            elif args.gpg == "rw":
                rw_binds.append((gnupg_home, gnupg_home))

    if args.ro_path_env:
        paths = {
            pathlib.Path(s)
            for name in PATH_ENV_VARS
            for s in env_vars.get(name, "").split(":")
        }
        accessible_targets = {target for _, target in ro_binds + rw_binds} | {
            target for target, _ in symlinks
        }
        ro_binds += {
            (path, path)
            for path in paths
            if path.exists()
            and not any(path.is_relative_to(target) for target in accessible_targets)
        }

    if args.wayland:
        wayland_socket = pathlib.Path(os.environ["WAYLAND_DISPLAY"])
        if not wayland_socket.is_absolute():
            wayland_socket = (
                pathlib.Path(os.environ["XDG_RUNTIME_DIR"]) / wayland_socket
            )
        wayland_display = "wayland-0"
        env_vars["WAYLAND_DISPLAY"] = wayland_display
        ro_binds.append((wayland_socket, XDG_RUNTIME_DIR / wayland_display))

    if args.x11:
        display = os.environ["DISPLAY"]
        try:
            xauthority = pathlib.Path(os.environ["XAUTHORITY"])
        except KeyError:
            xauthority = pathlib.Path.home() / ".Xauthority"
        env_vars["DISPLAY"] = display
        env_vars["XAUTHORITY"] = str(xauthority)
        x11_socket = pathlib.Path("/tmp/.X11-unix")
        ro_binds += [
            (xauthority, xauthority),
            (x11_socket, x11_socket),
        ]

    base_args = [*BWRAP_BASE_ARGS]
    if legacy_tiocsti_enabled():
        base_args.append("--new-session")

    ro_binds = sorted(set(ro_binds) - set(rw_binds))
    rw_binds = sorted(set(rw_binds))
    symlinks = sorted(set(symlinks))

    additional_users = ["root", "nobody"]
    injected_files = {
        pathlib.Path("/etc/passwd"): prepare_injectable_file(
            subprocess.run(
                ["getent", "passwd", str(os.getuid()), *additional_users],
                capture_output=True,
                check=True,
            ).stdout
        ),
        pathlib.Path("/etc/group"): prepare_injectable_file(
            subprocess.run(
                ["getent", "group", str(os.getgid()), *additional_users],
                capture_output=True,
                check=True,
            ).stdout
        ),
    }

    use_systemd_run = systemd_user_manager_available()
    systemd_scope = (
        f"isolate-env-{escaped_path(cwd)}-{secrets.token_hex(4)}"
        if use_systemd_run
        else None
    )

    if args.verbose:
        debug = build_debug_output(
            base_args=base_args,
            env_vars=env_vars,
            escape_flags={
                "docker": args.docker,
                "gpg": args.gpg is not None,
                "wayland": args.wayland,
                "x11": args.x11,
            },
            injected_files=injected_files,
            ro_binds=ro_binds,
            rw_binds=rw_binds,
            symlinks=symlinks,
            systemd_scope=systemd_scope,
        )
        print(debug, file=sys.stderr)

    exec_args: list[str | os.PathLike] = []
    if use_systemd_run:
        exec_args += [
            "systemd-run",
            "--collect",
            "--same-dir",
            "--scope",
            f"--unit={systemd_scope}",
            "--property=TasksMax=512",
            "--user",
            "--verbose" if args.verbose else "--quiet",
        ]
    exec_args += ["bwrap", *base_args]
    for source, target in symlinks:
        exec_args += ["--symlink", target.relative_to(source.parent), source]
    for bind_entry in sorted(
        [
            *(("--ro-bind", source, target) for source, target in ro_binds),
            *(("--bind", source, target) for source, target in rw_binds),
        ],
        key=operator.itemgetter(1),
    ):
        exec_args += bind_entry
    for target, fp in injected_files.items():
        exec_args += ["--perms", "0644", "--file", str(fp.fileno()), target]
    for path in REMOUNT_RO_BIND_MOUNTS:
        exec_args += ["--remount-ro", path]
    exec_args.append("--clearenv")
    for name, value in env_vars.items():
        exec_args += ["--setenv", name, value]
    exec_args += command
    os.execvpe(exec_args[0], exec_args, os.environ)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Run a command inside a bubblewrap-based isolated environment.",
    )
    security_note = "(note: security risk)"
    parser.add_argument(
        "--cwd",
        choices=["rw", "ro", "no"],
        default="rw",
        help="mount cwd as rw (default), ro, or not at all",
    )
    parser.add_argument(
        "--docker",
        action="store_true",
        help=f"propagate Docker socket {security_note}",
    )
    parser.add_argument(
        "--gpg",
        choices=["rw", "ro", "no"],
        default="no",
        help=f"propagate GnuPG as ro (default) or rw, or not at all {security_note}",
    )
    parser.add_argument(
        "--env",
        action="append",
        default=[],
        metavar="NAME=value",
        help="propagate env var, e.g. NAME, NAME=value, NAME_* (glob)",
    )
    bind_metavar = "from[:to]"
    parser.add_argument(
        "--ro",
        action="append",
        default=[],
        metavar=bind_metavar,
        help="add read-only bind mount",
        type=parse_bind,
    )
    parser.add_argument(
        "--ro-path-env",
        action=argparse.BooleanOptionalAction,
        default=True,
        help=(
            f"bind mount dirs from env vars "
            f"(default on, using {' + '.join(PATH_ENV_VARS)})"
        ),
    )
    parser.add_argument(
        "--rw",
        action="append",
        default=[],
        metavar=bind_metavar,
        help="add read-write bind mount",
        type=parse_bind,
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="print debug output",
    )
    parser.add_argument(
        "--wayland",
        action="store_true",
        help=f"propagate Wayland display socket {security_note}",
    )
    parser.add_argument(
        "--x11",
        action="store_true",
        help=f"propagate X11 display socket {security_note}",
    )
    subparsers = parser.add_subparsers(
        dest="subcommand",
        help="available subcommands",
        required=True,
        title="subcommands",
    )
    run_parser = subparsers.add_parser(
        "run",
        description="Run a command inside the isolated environment.",
        help="run a command",
    )
    run_parser.add_argument(
        "command", metavar=("command", "arg", "..."), nargs=argparse.REMAINDER
    )
    subparsers.add_parser(
        "shell",
        description="Start an interactive shell inside the isolated environment.",
        help="run an interactive shell",
    )
    if argcomplete:
        argcomplete.autocomplete(parser)
    return parser.parse_args()


def normalize_binds(
    paths: Iterable[str],
    *,
    resolve_symlinks: bool = False,
) -> Iterator[Bind]:
    for s in paths:
        path = pathlib.Path(s).expanduser()
        if not path.exists():
            continue
        source = path.resolve() if resolve_symlinks else path
        yield source, path


def normalize_binds_or_symlinks(
    inputs: Iterable[str],
) -> tuple[list[Bind], list[Symlink]]:
    paths = [path for s in inputs if (path := pathlib.Path(s).expanduser()).exists()]
    bind_roots = {path for path in paths if not path.is_symlink()}
    binds = []
    symlinks = []
    for path in paths:
        if path.is_symlink():
            target = path.resolve()
            if any(target.is_relative_to(root) for root in bind_roots):
                symlinks.append((path, target))
                continue

        binds.append((path, path))
    return binds, symlinks


def parse_bind(spec: str) -> Bind:
    source, sep, target = spec.partition(":")
    if not source:
        raise argparse.ArgumentTypeError("source path is empty")
    source_path = pathlib.Path(source).expanduser().absolute()
    if not sep:
        target_path = source_path
    elif target:
        target_path = pathlib.Path(target).expanduser().absolute()
    else:
        raise argparse.ArgumentTypeError("target path is empty")
    return source_path, target_path


def prepare_injectable_file(data: bytes) -> typing.BinaryIO:
    fp = tempfile.TemporaryFile()
    fp.write(data)
    fp.seek(0)
    os.set_inheritable(fp.fileno(), True)
    return fp


def detect_docker() -> tuple[str, pathlib.Path | None]:
    try:
        docker_host = os.environ["DOCKER_HOST"]
    except KeyError:
        docker_host = subprocess.run(
            [
                "docker",
                "context",
                "inspect",
                "--format",
                "{{.Endpoints.docker.Host}}",
            ],
            capture_output=True,
            check=True,
            text=True,
        ).stdout.strip()
        if not docker_host:
            raise RuntimeError("Docker context has no endpoint")
    docker_socket = (
        pathlib.Path(docker_host.removeprefix("unix://"))
        if docker_host.startswith("unix://")
        else None
    )
    return docker_host, docker_socket


def detect_gnupg() -> tuple[pathlib.Path, pathlib.Path]:
    try:
        gnupg_home = pathlib.Path(os.environ["GNUPGHOME"]).absolute()
    except KeyError:
        gnupg_home = pathlib.Path.home() / ".gnupg"
    socket_dir = pathlib.Path(
        subprocess.run(
            ["gpgconf", "--list-dirs", "socketdir"],
            capture_output=True,
            check=True,
            text=True,
        ).stdout.strip()
    )
    if not gnupg_home.is_dir() or not socket_dir or not socket_dir.is_dir():
        raise RuntimeError("invalid gpg home dir or socket dir")
    return gnupg_home, socket_dir


def shell_history_bind(
    shell: pathlib.Path,
    cwd: pathlib.Path,
) -> Bind | None:
    match shell.name:
        case "bash":
            name = ".bash_history"
        case "zsh":
            name = ".zsh_history"
        case "fish":
            name = ".local/share/fish/fish_history"
        case _:
            return None
    home = pathlib.Path.home()
    source = home / f"{name}.d" / escaped_path(cwd)
    target = home / name
    return source, target


def escaped_path(path: pathlib.Path) -> str:
    return subprocess.run(
        ["systemd-escape", "--path", path],
        capture_output=True,
        check=True,
        text=True,
    ).stdout.strip()


def systemd_user_manager_available() -> bool:
    try:
        runtime_dir = pathlib.Path(os.environ["XDG_RUNTIME_DIR"])
    except KeyError:
        return False
    return (runtime_dir / "systemd/private").is_socket()


def legacy_tiocsti_enabled() -> bool:
    path = pathlib.Path("/proc/sys/dev/tty/legacy_tiocsti")
    if not path.exists():
        # Older kernels lack this sysctl and allow TIOCSTI by default.
        return True
    return path.read_text().strip() != "0"


def obtain_env_vars(specs: Iterable[str]) -> dict[str, str]:
    env_vars = {}
    for spec in specs:
        name, sep, value = spec.partition("=")
        if sep:
            env_vars[name] = value
            continue
        for name, value in os.environ.items():
            if fnmatch.fnmatch(name, spec):
                env_vars[name] = value
    return env_vars


def build_debug_output(
    *,
    base_args: list[str],
    env_vars: dict[str, str],
    escape_flags: dict[str, bool],
    injected_files: Iterable[pathlib.Path],
    ro_binds: list[Bind],
    rw_binds: list[Bind],
    symlinks: list[Symlink],
    systemd_scope: str | None,
) -> str:
    lines = []

    if systemd_scope:
        lines.append(f"systemd scope: {systemd_scope}")

    lines.append("escape flags:")
    for name, enabled in escape_flags.items():
        lines.append(f"  {name}: {'enabled' if enabled else 'disabled'}")

    lines.append("bwrap arguments:")
    for arg in base_args:
        lines.append(f"  {arg}")

    lines.append("read-write bind mounts:")
    for source, target in rw_binds:
        lines.append(f"  {prettify_path_pair(source, target)}")

    lines.append("read-only bind mounts:")
    for source, target in ro_binds:
        lines.append(f"  {prettify_path_pair(source, target)}")

    lines.append("symlinks:")
    for source, target in symlinks:
        lines.append(
            f"  {prettify_path_pair(source, target.relative_to(source.parent))}"
        )

    lines.append("injected files:")
    for path in sorted(injected_files):
        lines.append(f"  {prettify_path(path)}")

    lines.append("environment variables:")
    for name, value in sorted(env_vars.items()):
        if name.endswith(("DIRS", "PATH")):
            lines.append(f"  {name}=")
            for entry in value.split(":"):
                path = pathlib.Path(entry)
                lines.append(f"    {prettify_path(path)}")
        else:
            lines.append(f"  {name}={value}")
    return "\n".join(lines)


def prettify_path(path: pathlib.Path) -> str:
    path = pathlib.Path(path).expanduser()
    home = pathlib.Path.home()
    if path == home:
        return "~"
    if home in path.parents:
        return str(pathlib.Path("~") / path.relative_to(home))
    return str(path)


def prettify_path_pair(source: pathlib.Path, target: pathlib.Path) -> str:
    if source == target:
        return prettify_path(source)
    return f"{prettify_path(source)} → {prettify_path(target)}"


if __name__ == "__main__":
    main()
